local Kavo = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Kavo.CreateLib("Shindo Recolor", "GrapeTheme")

local player = game:GetService("Players").LocalPlayer
local startevent = player:WaitForChild("startevent")

local function toShindoColor(color)
    local r = tonumber(string.format("%.3f", color.r))
    local g = tonumber(string.format("%.3f", color.g))
    local b = tonumber(string.format("%.3f", color.b))
    return r .. "," .. g .. "," .. b
end

local Tab1 = Window:NewTab("Appearance")
local Section1 = Tab1:NewSection("Visual Customize")

Section1:NewColorPicker("Hair Color", "Change hair color", Color3.fromRGB(255,255,255), function(color)
    startevent:FireServer("haircolor", toShindoColor(color))
end)

Section1:NewColorPicker("Skin Color", "Change skin race color", Color3.fromRGB(255,0,0), function(color)
    startevent:FireServer("skin", toShindoColor(color))
end)

