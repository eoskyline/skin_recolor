local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Labelay",
   LoadingTitle = "Caue dando o cu...",
   LoadingSubtitle = "may work idk",
   ConfigurationSaving = { Enabled = false }
})

local player = game:GetService("Players").LocalPlayer
local startevent = player:WaitForChild("startevent")
local targetPlayer = ""
local tracking = false
local rainbowActive = false


local function formatColor(c)
    return string.format("%f,%f,%f", c.R, c.G, c.B)
end


local AppearanceTab = Window:CreateTab("Aparência", 4483345998)

AppearanceTab:CreateColorPicker({
    Name = "Hair Color",
    Default = Color3.fromRGB(255, 255, 255),
    Callback = function(Value)
        startevent:FireServer("hair", formatColor(Value))
    end
})

AppearanceTab:CreateColorPicker({
    Name = "Skin Color",
    Default = Color3.fromRGB(255, 0, 0),
    Callback = function(Value)
        startevent:FireServer("skin", formatColor(Value))
    end
})

AppearanceTab:CreateToggle({
    Name = "Rainbow Mode",
    CurrentValue = false,
    Callback = function(Value)
        rainbowActive = Value
        if rainbowActive then
            task.spawn(function()
                while rainbowActive do
                    for i = 0, 1, 0.01 do
                        if not rainbowActive then break end
                        local color = Color3.fromHSV(i, 1, 1)
                        startevent:FireServer("skin", formatColor(color))
                        task.wait(0.1)
                    end
                end
            end)
        end
    end
})


local MonitorTab = Window:CreateTab("Monitor HP", 4483345998)

local LabelNome = MonitorTab:CreateLabel("Alvo: None")
local LabelHP = MonitorTab:CreateLabel("HP: --- / ---")

MonitorTab:CreateInput({
   Name = "Player Name",
   PlaceholderText = "Name...",
   Callback = function(Text)
      targetPlayer = Text
      LabelNome:Set("Target: " .. targetPlayer)
   end,
})

MonitorTab:CreateToggle({
   Name = "HP windown",
   CurrentValue = false,
   Callback = function(Value)
      tracking = Value
      if tracking then
         task.spawn(function()
            while tracking do
               local p = game.Players:FindFirstChild(targetPlayer)
               if p then
                  local stats = p:FindFirstChild("StatStorage")
                  local hpObj = stats and (stats:FindFirstChild("fakehealth") or stats:FindFirstChild("Health"))
                  local maxHpObj = stats and stats:FindFirstChild("MaxHealth")
                  
                  local char = p.Character
                  local hum = char and char:FindFirstChild("Humanoid")

                  local atual = hpObj and hpObj.Value or (hum and hum.Health or 0)
                  local maximo = maxHpObj and maxHpObj.Value or (hum and hum.MaxHealth or 0)

                  LabelHP:Set(string.format("HP: %d / %d", math.floor(atual), math.floor(maximo)))
               else
                  LabelHP:Set("Jogador não encontrado ou Offline")
               end
               task.wait(0.5) -- Atualização rápida para ver o HP caindo em tempo real
            end
            LabelHP:Set("HP: --- / ---")
         end)
      end
   end,
})
